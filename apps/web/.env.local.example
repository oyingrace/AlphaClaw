# API (required for web to talk to backend)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Stacks explorer (optional; defaults to https://explorer.hiro.so)
# NEXT_PUBLIC_STACKS_EXPLORER_URL=https://explorer.hiro.so

# Stacks chain configuration for AlphaClaw
# Network can be "mainnet" or "testnet"
NEXT_PUBLIC_STACKS_NETWORK=testnet
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Contract IDs for the AlphaClaw staking demo on Stacks
# Replace these placeholders with your deployed testnet IDs:
# e.g. ST...alphaclaw and ST...RewardToken
NEXT_PUBLIC_STACKS_STAKING_CONTRACT_ID=
NEXT_PUBLIC_STACKS_REWARD_TOKEN_CONTRACT_ID=
